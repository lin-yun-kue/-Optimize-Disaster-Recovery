GENTYPE Default;

QUEUE Start Default;
COMBI Middle;
QUEUE End Default;
QUEUE DispatchSem0 Default;
COMBI Work0;

LINK L1 Start Middle;
LINK L2 Middle End;
LINK L3 DispatchSem0 Work0;
LINK L4 Work0 End;

EZINITIALCONTENT Start 3;
PRIORITY Middle 0;
SEMAPHORE Middle 1;
DURATION Middle 0;
EZINITIALCONTENT DispatchSem0 0;
PRIORITY Work0 0;
SEMAPHORE Work0 1;
DURATION Work0 10;

ENOUGH L1 CurCount>0;
DRAWUNTIL L1 nDraws;
DRAWAMT L1 1;
DRAWORDER L1 1;
DRAWWHERE L1 1;
RELEASEAMT L1 1;
RELEASEUNTIL L1 0;
RELEASEORDER L1 1;
RELEASEWHERE L1 1;
STRENGTH L1 1;

ENOUGH L2 1;
DRAWUNTIL L2 nDraws;
DRAWAMT L2 1;
DRAWORDER L2 1;
DRAWWHERE L2 1;
RELEASEAMT L2 1;
RELEASEUNTIL L2 0;
RELEASEORDER L2 1;
RELEASEWHERE L2 1;
STRENGTH L2 1;

ENOUGH L3 CurCount>0;
DRAWUNTIL L3 nDraws;
DRAWAMT L3 1;
DRAWORDER L3 1;
DRAWWHERE L3 1;
RELEASEAMT L3 1;
RELEASEUNTIL L3 0;
RELEASEORDER L3 1;
RELEASEWHERE L3 1;
STRENGTH L3 1;

ENOUGH L4 1;
DRAWUNTIL L4 nDraws;
DRAWAMT L4 1;
DRAWORDER L4 1;
DRAWWHERE L4 1;
RELEASEAMT L4 1;
RELEASEUNTIL L4 0;
RELEASEORDER L4 1;
RELEASEWHERE L4 1;
STRENGTH L4 1;

RANDOMSEED true;
SEED 0;
STREAMS 0;
NUMRUNS 1;
ENDCOND SimTime>=100000;

/<CODE>
ONENTRY Start SAVEVALUE _choice 0;
ONSTART Middle POST "OBS:simtime={SimTime},curcount={Start.CurCount}";
ONSTART Middle ASSIGN _choice GET("my-get-id");
IF _choice==0 ADDTOQUEUE DispatchSem0 1;
/<CODE>

POSLINK L1 0 1;
POSLINK L2 0 1;
POSLINK L3 0 1;
POSLINK L4 0 1;
POSNODE Start 0 0;
POSNODE Middle 100 0;
POSNODE End 200 0;
POSNODE DispatchSem0 300 0;
POSNODE Work0 400 0;
RANKCOUNT 0;
