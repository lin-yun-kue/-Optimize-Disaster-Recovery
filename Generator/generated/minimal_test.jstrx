GENTYPE Default;

QUEUE Go Default;
QUEUE Sink Default;

LINK L1 Go Sink;

EZINITIALCONTENT Go 1;

ENOUGH L1 CurCount>0.0;
DRAWUNTIL L1 nDraws;
DRAWAMT L1 1;
DRAWORDER L1 1;
DRAWWHERE L1 1;
RELEASEAMT L1 1;
RELEASEUNTIL L1 0;
RELEASEORDER L1 1;
RELEASEWHERE L1 1;
STRENGTH L1 1;

RANDOMSEED true;
SEED 0;
STREAMS 0;
NUMRUNS 1;
ENDCOND SimTime>=1000;

POSLINK L1 0 1;
POSNODE Go 0.0 0.0;
POSNODE Sink 100.0 0.0;
RANKCOUNT 0;
